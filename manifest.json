{
  "manifest_version": 3,
  "name": "Reverse AutoScroll",
  "version": "1.1.0",
  "description": "Middle-click autoscroll with reversed direction on regular web pages.",
  "homepage_url": "https://github.com/kicucya/reverse-autoscroll-extension",
  "minimum_chrome_version": "114",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}

